<?xml version="1.0" encoding="utf-8"?>
<!-- SnapDog Client template — 11 communication objects per client -->
<Module xmlns="http://knx.org/xml/project/20">

  <ComObject>
    <ComObject Name="Client %C% Volume"           Number="%K0%"  FunctionText="Volume"           DatapointType="DPST-5-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Volume Status"    Number="%K1%"  FunctionText="Volume Status"    DatapointType="DPST-5-1"  Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Volume Dim"       Number="%K2%"  FunctionText="Volume Dim"       DatapointType="DPST-3-7"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Mute"             Number="%K3%"  FunctionText="Mute"             DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Mute Status"      Number="%K4%"  FunctionText="Mute Status"      DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Mute Toggle"      Number="%K5%"  FunctionText="Mute Toggle"      DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Latency"          Number="%K6%"  FunctionText="Latency"          DatapointType="DPST-5-10" Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Latency Status"   Number="%K7%"  FunctionText="Latency Status"   DatapointType="DPST-5-10" Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Zone"             Number="%K8%"  FunctionText="Zone"             DatapointType="DPST-5-10" Priority="Low" ReadFlag="Enabled"  WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Enabled" />
    <ComObject Name="Client %C% Zone Status"      Number="%K9%"  FunctionText="Zone Status"      DatapointType="DPST-5-10" Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Client %C% Connected"        Number="%K10%" FunctionText="Connected"        DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
  </ComObject>

  <Dynamic>
    <!-- ETS shows these COs grouped under the client channel -->
  </Dynamic>

</Module>
