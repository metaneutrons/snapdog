<?xml version="1.0" encoding="utf-8"?>
<KNX xmlns="http://knx.org/xml/project/20" xmlns:op="http://github.com/OpenKNX/OpenKNXproducer">

  <op:ETS
    OpenKnxId="0xFF"
    ApplicationNumber="1"
    ApplicationVersion="1"
    ReplacesVersions="0.0"
    ApplicationRevision="0"
    ProductName="SnapDog"
    IsIPEnabled="true"
    BusCurrent="0"
  />

  <!-- No firmware parameters — minimal memory size -->
  <op:config name="%MemorySize%" value="1" />
  <op:config name="%MID%" value="M-00FA_A-FF01-01-0000_RS-04-00000" />

  <!-- Zone module: 30 KOs per zone, 10 zones, KO 1-300 -->
  <op:define prefix="ZONE" header="include/knxprod.h"
    share=""
    template="SnapDog-Zone.templ.xml"
    NumChannels="10"
    KoOffset="1"
    ModuleType="1"
  />

  <!-- Client module: 11 KOs per client, 10 clients, KO 301-410 -->
  <op:define prefix="CLI" header="include/knxprod.h"
    share=""
    template="SnapDog-Client.templ.xml"
    NumChannels="10"
    KoOffset="301"
    ModuleType="2"
  />

  <generate />

</KNX>
