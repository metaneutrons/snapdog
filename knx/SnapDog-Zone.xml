    <ComObject Name="Zone %C% Track Title"         Number="%K26%" FunctionText="Track Title"         DatapointType="DPST-16-1" Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Track Artist"        Number="%K27%" FunctionText="Track Artist"        DatapointType="DPST-16-1" Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Track Album"         Number="%K28%" FunctionText="Track Album"         DatapointType="DPST-16-1" Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
