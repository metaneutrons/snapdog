    <ComObject Name="Zone %C% Playlist"            Number="%K22%" FunctionText="Playlist"            DatapointType="DPST-5-10" Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Playlist Status"     Number="%K23%" FunctionText="Playlist Status"     DatapointType="DPST-5-10" Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Playlist Next"       Number="%K24%" FunctionText="Playlist Next"       DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Playlist Previous"   Number="%K25%" FunctionText="Playlist Previous"   DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
