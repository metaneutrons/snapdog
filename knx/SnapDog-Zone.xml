    <!-- Shuffle -->
    <ComObject Name="Zone %C% Shuffle"             Number="%K13%" FunctionText="Shuffle"             DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Shuffle Status"      Number="%K14%" FunctionText="Shuffle Status"      DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
