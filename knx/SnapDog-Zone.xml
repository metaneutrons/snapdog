    <ComObject Name="Zone %C% Control Status"      Number="%K11%" FunctionText="Control Status"      DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
