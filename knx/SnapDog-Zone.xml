<?xml version="1.0" encoding="utf-8"?>
<!-- SnapDog Zone template — 30 communication objects per zone -->
<Module xmlns="http://knx.org/xml/project/20">

  <ComObject>
    <!-- Transport commands (receive) -->
    <ComObject Name="Zone %C% Play"                Number="%K0%"  FunctionText="Play"                DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Pause"               Number="%K1%"  FunctionText="Pause"               DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Stop"                Number="%K2%"  FunctionText="Stop"                DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Track Next"          Number="%K3%"  FunctionText="Track Next"          DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Track Previous"      Number="%K4%"  FunctionText="Track Previous"      DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <!-- Volume -->
    <ComObject Name="Zone %C% Volume"              Number="%K5%"  FunctionText="Volume"              DatapointType="DPST-5-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Volume Status"       Number="%K6%"  FunctionText="Volume Status"       DatapointType="DPST-5-1"  Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Volume Dim"          Number="%K7%"  FunctionText="Volume Dim"          DatapointType="DPST-3-7"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <!-- Mute -->
    <ComObject Name="Zone %C% Mute"                Number="%K8%"  FunctionText="Mute"                DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Mute Status"         Number="%K9%"  FunctionText="Mute Status"         DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Enabled"  WriteFlag="Disabled" CommunicationFlag="Enabled" TransmitFlag="Enabled"  UpdateFlag="Disabled" />
    <ComObject Name="Zone %C% Mute Toggle"         Number="%K10%" FunctionText="Mute Toggle"         DatapointType="DPST-1-1"  Priority="Low" ReadFlag="Disabled" WriteFlag="Enabled" CommunicationFlag="Enabled" TransmitFlag="Disabled" UpdateFlag="Disabled" />
